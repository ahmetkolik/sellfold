# ─────────────────────────────────────────────────────────────────────────────
#  Vitrin — .env.example. Copy to .env.local and fill in.
#
#  The guided setup ("/setup" in Claude Code) does this FOR you. Every key is
#  OPTIONAL — with none set, Vitrin runs in DEMO MODE with sample products,
#  sales and customers.
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe — card checkout for one-time & subscription product sales ─────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# ── Resend — branded instant-delivery & receipt emails to buyers ─────────────
# https://resend.com/api-keys
RESEND_API_KEY=

# ── Supabase — stores products, sales & customers (optional) ─────────────────
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
